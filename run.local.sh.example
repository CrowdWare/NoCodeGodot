#!/usr/bin/env bash

# Copy this file to `run.local.sh` and customize it for your private workflow.
# `run.local.sh` is ignored by git and loaded automatically by `run.sh`.
#
# Supported override modes:
#   release, docs, test, export, app, poser, pub
#
# Contract:
# - Return 0 if this local handler fully handled the mode.
# - Return non-zero to fall back to the default `run.sh` behavior.

# Optional: set local machine paths/env here (git-ignored in run.local.sh).
# export GODOT_CPP_DIR="/absolute/path/to/godot-cpp"
# export FORGE_PUB_REMOTE="codeberg"
# export FORGE_PUB_BRANCH="main"

forge_local_handle_mode() {
  local mode="$1"
  shift || true

  case "$mode" in
    release)
      echo "[local] release override not configured yet."
      return 1
      ;;
    docs)
      echo "[local] docs override not configured yet."
      return 1
      ;;
    test)
      echo "[local] test override not configured yet."
      return 1
      ;;
    pub)
      echo "[local] pub override not configured yet."
      return 1
      ;;
    export)
      echo "[local] export override not configured yet."
      return 1
      ;;
    app)
      echo "[local] app override not configured yet."
      return 1
      ;;
    poser)
      echo "[local] poser override not configured yet."
      return 1
      ;;
    *)
      return 1
      ;;
  esac
}
