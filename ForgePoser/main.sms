// ── Keyframe inspector ────────────────────────────────────────────────────────

fun updateKeyframeTree() {
    kfTreeRef.Clear()
    var root = kfTreeRef.CreateRoot("Keyframes", "root")
    var charCount = editor.getSceneCharacterCount()
    if (charCount <= 0) {
        return
    }
    var selectedCharId = editor.getActiveCharacterId()
    if (selectedCharId == "") {
        var charIdx = selectedSceneAssetIndex
        if (charIdx < 0 || charIdx >= charCount) {
            charIdx = 0
        }
        selectedCharId = editor.getSceneCharacterId(charIdx)
    }
    if (selectedCharId == "") {
        return
    }

    timeline.setVisibleCharacterId(selectedCharId)

    var count = timeline.getKeyframeCountForCharacter(selectedCharId)
    var i = 0
    while (i < count) {
        var frame = timeline.getKeyframeFrameAtForCharacter(i, selectedCharId)
        var boneCount = timeline.getKeyframeBoneCountForCharacter(frame, selectedCharId)
        if (boneCount > 0) {
            kfTreeRef.CreateChild(root, "Frame " + frame + " (" + boneCount + " bones)", frame, false)
        }
        i = i + 1
    }

    // Enable this only when debugging keyframe scoping issues:
    // timeline.debugLogKeyframesForCharacter(selectedCharId)
}

on timeline.keyframeAdded(frame, boneName) {
    updateKeyframeTree()
}

on timeline.keyframeRemoved(frame) {
    updateKeyframeTree()
}

// ── PosingEditor events ───────────────────────────────────────────────────────

on editor.boneSelected(boneName) {
    statusLabel.text = "Selected: " + boneName
}

on editor.poseChanged(boneName) {
    timeline.setKeyframe(timeline.currentFrame, editor.getPoseDataForActiveCharacter())
}

on editor.poseReset() {
    statusLabel.text = "Pose reset."
}

// ── Timeline events ───────────────────────────────────────────────────────────

on timeline.frameChanged(frame) {
    var pose = timeline.getPoseAt(frame)
    if (pose != null) {
        editor.loadPose(pose)
    }
}

on timeline.playbackStarted() {
    statusLabel.text = "Playing…"
}

on timeline.playbackStopped() {
    statusLabel.text = "Stopped."
}

on keyframeTree.itemSelected() {
    // pass
}

on boneTree.itemSelected() {
    // Bone rotation drag works only in pose mode.
    if (currentMode != "pose") {
        activatePoseMode()
        statusLabel.text = "Pose Mode"
    }
}

// ── Mode toolbar ──────────────────────────────────────────────────────────

on btnPoseMode.clicked() {
    activatePoseMode()
    statusLabel.text = "Pose Mode"
}

on btnArrangeMode.clicked() {
    activateArrangeMove()
    // Re-attach gizmo to already-selected scene asset (if any)
    var sel = selectedSceneAssetIndex
    if (sel >= 0) {
        var charCount = editor.getSceneCharacterCount()
        if (sel < charCount) {
            editor.selectSceneCharacter(sel)
        } else {
            var propIdx = sel - charCount
            if (propIdx >= 0) {
                editor.selectSceneProp(propIdx)
            }
        }
    }
    updateInspectorFromSelection()
    statusLabel.text = "Arrange Mode"
}

on btnModeMove.clicked() {
    currentEditMode = "move"
    ui.getObject("btnModeMove").buttonPressed = true
    ui.getObject("btnModeScale").buttonPressed = false
    ui.getObject("btnModeRotate").buttonPressed = false
    editor.setEditMode("move")
}

on btnModeScale.clicked() {
    currentEditMode = "scale"
    ui.getObject("btnModeMove").buttonPressed = false
    ui.getObject("btnModeScale").buttonPressed = true
    ui.getObject("btnModeRotate").buttonPressed = false
    editor.setEditMode("scale")
}

on btnModeRotate.clicked() {
    currentEditMode = "rotate"
    ui.getObject("btnModeMove").buttonPressed = false
    ui.getObject("btnModeScale").buttonPressed = false
    ui.getObject("btnModeRotate").buttonPressed = true
    editor.setEditMode("rotate")
}

on transformSpaceSelect.itemSelected(index) {
    applyTransformSpace(index)
    statusLabel.text = "Transform Space: " + currentTransformSpace
}

on transformSpaceSelect.clicked() {
    // OptionButton emits clicked in some runtime paths; keep handler to avoid warning spam.
}

// ── Viewport controls ─────────────────────────────────────────────────────────

on btnToggleJoints.clicked() {
    if (jointSpheresVisible) {
        jointSpheresVisible = false
        editor.setJointSpheresVisible(false)
        ui.getObject("btnToggleJoints").buttonPressed = false
        statusLabel.text = "Joints hidden."
    } else {
        jointSpheresVisible = true
        editor.setJointSpheresVisible(true)
        ui.getObject("btnToggleJoints").buttonPressed = true
        statusLabel.text = "Joints visible."
    }
}

// ── Project chooser ───────────────────────────────────────────────────────────

on btnChooserOpenLast.clicked() {
    var last = readLastProjectPath()
    if (last == "" || !os.fileExists(last)) {
        showProjectChooser("Last project not found. Choose Open or Create.")
        return
    }
    if (!openProjectPath(last)) {
        showProjectChooser("Last project could not be opened.")
    }
}

on btnChooserOpen.clicked() {
    ui.openFileDialog("onProjectFileSelected", "*.scene")
}

on btnChooserCreate.clicked() {
    ui.openSaveFileDialog("onProjectCreatePathSelected", "*.scene")
}

on btnChooserThemePrev.clicked() {
    applyThemePreset(selectedThemeIndex - 1)
}

on btnChooserThemeNext.clicked() {
    applyThemePreset(selectedThemeIndex + 1)
}

on btnChooserCancel.clicked() {
    var win = ui.getObject("mainWindow")
    if (win != null) {
        var tree = win.getTree()
        if (tree != null) {
            tree.quit()
        } else {
            win.close()
        }
    }
}
