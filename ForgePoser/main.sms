    kfTreeRef    = ui.getObject("keyframeTree")
    sceneTreeRef = ui.getObject("sceneAssetTree")
    editor       = ui.getObject("editor")
    sourceEditorRef = ui.getObject("sourceEditor")
    promptEditorRef = ui.getObject("promptEditor")
    negativePromptEditRef = ui.getObject("negativePromptEdit")
    styleImagePathEditRef = ui.getObject("styleImagePathEdit")
    extraImagePathEditRef = ui.getObject("extraImagePathEdit")
    timeline     = ui.getObject("timeline")
    statusLabel  = ui.getObject("statusLabel")
    rightDockRef = ui.getObject("rightDock")
    rightBottomDockRef = ui.getObject("rightBottomDock")
    bonesPanelRef = ui.getObject("bonesPanel")
    inspectorPanelRef = ui.getObject("inspectorPanel")
    inspectorTargetLabel = ui.getObject("inspectorTargetLabel")
    inspPosX = ui.getObject("inspPosX")
    inspPosY = ui.getObject("inspPosY")
    inspPosZ = ui.getObject("inspPosZ")
    inspRotX = ui.getObject("inspRotX")
    inspRotY = ui.getObject("inspRotY")
    inspRotZ = ui.getObject("inspRotZ")
    inspScaleX = ui.getObject("inspScaleX")
    inspScaleY = ui.getObject("inspScaleY")
    inspScaleZ = ui.getObject("inspScaleZ")
    transformInspectorPanel = ui.getObject("transformInspectorPanel")
    poseModeRotationPanel = ui.getObject("poseModeRotationPanel")
    poseRotX = ui.getObject("poseRotX")
    poseRotY = ui.getObject("poseRotY")
    poseRotZ = ui.getObject("poseRotZ")
    poseMinX = ui.getObject("poseMinX")
    poseMinY = ui.getObject("poseMinY")
    poseMinZ = ui.getObject("poseMinZ")
    poseMaxX = ui.getObject("poseMaxX")
    poseMaxY = ui.getObject("poseMaxY")
    poseMaxZ = ui.getObject("poseMaxZ")
    chooserOverlay = ui.getObject("projectChooserOverlay")
    chooserStatus  = ui.getObject("chooserStatus")
    chooserThemeLabel = ui.getObject("chooserThemeLabel")
    transformSpaceSelectRef = ui.getObject("transformSpaceSelect")
    mainDockHostRef = ui.getObject("mainDockHost")
    initThemePresets()
    applyThemePreset(0)
    refreshPromptPanelFromState()
    transformSpaceSelectRef.clear()
    transformSpaceSelectRef.addItem("World", 0)
    transformSpaceSelectRef.addItem("Local", 1)
    transformSpaceSelectRef.select(0)
    configureInspectorNumericFields()
    sceneTreeRef.BindEvents()
    editor.setBoneTree("boneTree")
    editor.setJointSpheresVisible(false)
    activateArrangeMove()
    applyTransformSpace(0)
    updateScenePanel()
    updateKeyframeTree()
    updateInspectorFromSelection()
    bootstrapProjectChooser()
    if (mainDockHostRef != null) {
        mainDockHostRef.ShowPanelById("sourcePanel")
    }
    log.success("ForgePoser is ready. Start posing.")
}

fun refreshDockingVisuals() {
    if (mainDockHostRef != null) {
        mainDockHostRef.QueueSort()
        mainDockHostRef.QueueRedraw()
    }

    var leftDock = ui.getObject("leftDock")
    if (leftDock != null) {
        leftDock.QueueRedraw()
    }
    var centerDock = ui.getObject("centerDock")
    if (centerDock != null) {
        centerDock.QueueRedraw()
    }
    var rightDock = ui.getObject("rightDock")
    if (rightDock != null) {
        rightDock.QueueRedraw()
    }
    var rightBottomDock = ui.getObject("rightBottomDock")
    if (rightBottomDock != null) {
        rightBottomDock.QueueRedraw()
    }
}

