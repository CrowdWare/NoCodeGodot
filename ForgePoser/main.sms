fun initThemePresets() {
    themeNames = []
    themeStylePaths = []
    themeExtraPaths = []

    themeNames.add("Default (style + clothing)")
    themeStylePaths.add("res:/input/style.jpg")
    themeExtraPaths.add("res:/input/clothing.jpg")

    themeNames.add("Sacred Look")
    themeStylePaths.add("res:/input/sacred.jpg")
    themeExtraPaths.add("res:/input/clothing.jpg")

    themeNames.add("Body Study")
    themeStylePaths.add("res:/input/style.jpg")
    themeExtraPaths.add("res:/input/muscles.jpg")
}

fun applyThemePreset(index) {
    if (themeNames.size <= 0) {
        return
    }
    if (index < 0) {
        index = themeNames.size - 1
    }
    if (index >= themeNames.size) {
        index = 0
    }
    selectedThemeIndex = index
    aiStyleImagePath = themeStylePaths[selectedThemeIndex]
    aiExtraImagePath = themeExtraPaths[selectedThemeIndex]
    if (chooserThemeLabel != null) {
        chooserThemeLabel.text = themeNames[selectedThemeIndex]
    }
    refreshPromptPanelFromState()
}

fun savePromptConfigForPath(path) {
    // Prompt persistence is handled by the plugin runtime (prompt.sml).
}

fun pushAiSceneProperties() {
    // Prompt persistence is handled by the plugin runtime (prompt.sml).
}

fun pullAiSceneProperties() {
    if (currentProjectPath == "") {
        return
    }
    try {
        var cfg = os.loadPromptConfig(currentProjectPath, aiPrompt, aiNegativePrompt, aiStyleImagePath, aiExtraImagePath, aiImageModel, aiVideoModel)
        if (cfg != null) {
            aiPrompt = cfg.prompt
            aiNegativePrompt = cfg.negativePrompt
            aiStyleImagePath = cfg.styleImagePath
            aiExtraImagePath = cfg.extraImagePath
            aiImageModel = cfg.imageModel
            aiVideoModel = cfg.videoModel
        }
    } catch (e) {
        log.warn("Prompt config unavailable: " + e.message)
    }
    refreshPromptPanelFromState()
}

fun refreshPromptPanelFromState() {
    if (promptEditorRef == null || negativePromptEditRef == null || styleImagePathEditRef == null || extraImagePathEditRef == null) {
        return
    }
    promptPanelWriteLock = true
    promptEditorRef.text = aiPrompt
    negativePromptEditRef.text = aiNegativePrompt
    styleImagePathEditRef.text = aiStyleImagePath
    extraImagePathEditRef.text = aiExtraImagePath
    promptPanelWriteLock = false
}

fun activateArrangeMove() {
    currentMode    = "arrange"
    currentEditMode = "move"
    ui.getObject("btnPoseMode").buttonPressed    = false
    ui.getObject("btnArrangeMode").buttonPressed = true
    ui.getObject("btnModeMove").visible   = true
    ui.getObject("btnModeMove").buttonPressed = true
    ui.getObject("btnModeScale").visible  = true
    ui.getObject("btnModeScale").buttonPressed = false
    ui.getObject("btnModeRotate").visible = true
    ui.getObject("btnModeRotate").buttonPressed = false
    ui.getObject("transformSpaceSelect").visible = true
    ui.getObject("btnToggleJoints").visible = false
    editor.setMode("arrange")
    editor.setEditMode("move")
    editor.setTransformSpace(currentTransformSpace)
    refreshInspectorModePanels()
}

fun activatePoseMode() {
    currentMode = "pose"
    ui.getObject("btnPoseMode").buttonPressed = true
    ui.getObject("btnArrangeMode").buttonPressed = false
    ui.getObject("btnModeMove").visible = false
    ui.getObject("btnModeScale").visible = false
    ui.getObject("btnModeRotate").visible = false
    ui.getObject("transformSpaceSelect").visible = false
    ui.getObject("btnToggleJoints").visible = true
    ui.getObject("btnToggleJoints").buttonPressed = jointSpheresVisible
    editor.setMode("pose")
    updatePoseInspectorFromEditor()
}

fun applyTransformSpace(index) {
    if (index == 1) {
        currentTransformSpace = "local"
    } else {
        currentTransformSpace = "world"
    }
    editor.setTransformSpace(currentTransformSpace)
}

fun selectFirstSceneAsset() {
    var charCount = editor.getSceneCharacterCount()
    if (charCount > 0) {
        selectSceneAssetByIndex(0)
        return
    }

    var propCount = editor.getScenePropCount()
    if (propCount > 0 && currentMode == "arrange") {
        selectSceneAssetByIndex(charCount)
    }
}

fun applyInitialPoseAfterLoad() {
    var targetFrame = 0
    var keyframeCount = timeline.getKeyframeCount()
    if (keyframeCount > 0) {
        var firstKeyframe = timeline.getKeyframeFrameAt(0)
        if (firstKeyframe > targetFrame) {
            targetFrame = firstKeyframe
        }
    }

    // Ensure frameChanged path runs at least once after project load.
    timeline.setCurrentFrame(timeline.totalFrames)
    timeline.setCurrentFrame(targetFrame)
    var pose = timeline.getPoseAt(targetFrame)
    if (pose != null) {
        editor.loadPose(pose)
    }
}

fun refreshSourceEditorFromProject() {
    if (sourceEditorRef == null || currentProjectPath == "") {
        return
    }
    if (isSourceEditorFocused()) {
        return
    }
    sourceEditorWriteLock = true
    sourceEditorRef.text = editor.getProjectText(currentProjectPath)
    sourceEditorWriteLock = false
    sourceEditorDirty = false
}

fun syncSceneToSource() {
    if (currentProjectPath == "") {
        return
    }
    pushAiSceneProperties()
    editor.saveProject(currentProjectPath)
    if (!isSourceEditorFocused()) {
        refreshSourceEditorFromDiskPreserveCursor()
    }
}

fun saveSourceEditorToProject(path) {
    if (sourceEditorRef == null || path == "") {
        return false
    }
    if (!sourceEditorDirty) {
        return false
    }
    os.writeFile(path, sourceEditorRef.text)
    sourceEditorDirty = false
    statusLabel.text = "Source saved: " + path
    return true
}

fun autoSaveCurrentProject() {
    if (currentProjectPath == "") {
        return
    }

    if (sourceEditorDirty) {
        if (sourceEditorRef != null) {
            var sourceText = sourceEditorRef.text
            var valid = ui.validateSmlSyntax(sourceText)
            if (!valid) {
                var err = ui.getLastSmlSyntaxError()
                statusLabel.text = "Syntax error: " + err
                return
            }
            sourceApplyInProgress = true
            var applied = editor.applyProjectText(currentProjectPath, sourceText, true)
            sourceApplyInProgress = false
            if (!applied) {
                statusLabel.text = "Apply failed (scene unchanged)."
                return
            }
            sourceApplyCooldownUntilMs = os.now() + 500
        }
        sourceEditorDirty = false
    } else {
        pushAiSceneProperties()
        editor.saveProject(currentProjectPath)
        if (!isSourceEditorFocused()) {
            refreshSourceEditorFromDiskPreserveCursor()
        }
    }

    statusLabel.text = "Auto-saved: " + currentProjectPath
}

fun isSourceEditorFocused() {
    if (sourceEditorRef == null) {
        return false
    }
    return sourceEditorRef.hasFocus()
}

fun requestAutoSave() {
    if (currentProjectPath == "") {
        return
    }

    autoSaveQueued = true
    var now = os.now()
    if (now >= autoSaveNextAllowedMs) {
        runAutoSaveTick()
        return
    }

    if (!autoSaveTimerArmed) {
        autoSaveTimerArmed = true
        var waitMs = autoSaveNextAllowedMs - now
        if (waitMs < 50) {
            waitMs = 50
        }
        ui.setTimeout("onAutoSaveTimer", waitMs)
    }
}

fun markInteractiveChange() {
    lastInteractiveChangeAtMs = os.now()
}

fun onAutoSaveTimer() {
    autoSaveTimerArmed = false
    runAutoSaveTick()
}

fun runAutoSaveTick() {
    if (!autoSaveQueued) {
        return
    }

    var now = os.now()
    if (sourceEditorDirty && sourceEditorLastChangeAtMs > 0) {
        var sourceIdleFor = now - sourceEditorLastChangeAtMs
        if (sourceIdleFor < sourceEditorIdleApplyMs) {
            if (!autoSaveTimerArmed) {
                autoSaveTimerArmed = true
                var waitSourceMs = sourceEditorIdleApplyMs - sourceIdleFor
                if (waitSourceMs < 50) {
                    waitSourceMs = 50
                }
                ui.setTimeout("onAutoSaveTimer", waitSourceMs)
            }
            return
        }
    }

    if (lastInteractiveChangeAtMs > 0) {
        var idleFor = now - lastInteractiveChangeAtMs
        if (idleFor < autoSaveInteractionIdleMs) {
            if (!autoSaveTimerArmed) {
                autoSaveTimerArmed = true
                var waitMs = autoSaveInteractionIdleMs - idleFor
                if (waitMs < 50) {
                    waitMs = 50
                }
                ui.setTimeout("onAutoSaveTimer", waitMs)
            }
            return
        }
    }

    autoSaveQueued = false
    autoSaveCurrentProject()
    autoSaveNextAllowedMs = os.now() + autoSaveDelayMs

    if (autoSaveQueued && !autoSaveTimerArmed) {
        autoSaveTimerArmed = true
        ui.setTimeout("onAutoSaveTimer", autoSaveDelayMs)
    }
}

fun refreshSourceEditorFromDiskPreserveCursor() {
    if (sourceEditorRef == null || currentProjectPath == "") {
        return
    }
    if (isSourceEditorFocused()) {
        return
    }
    if (sourceEditorDirty) {
        return
    }

    var latest = os.readFile(currentProjectPath)
    sourceEditorWriteLock = true
    sourceEditorRef.setTextPreserveCursor(latest)
    sourceEditorWriteLock = false
    sourceEditorDirty = false
}

fun scheduleInspectorRefresh() {
    if (inspectorRefreshArmed) {
        return
    }
    inspectorRefreshArmed = true
    ui.setTimeout("onInspectorRefreshTimer", 80)
}

fun onInspectorRefreshTimer() {
    inspectorRefreshArmed = false
    if (editor == null) {
        editor = ui.getObject("editor")
    }
    if (editor == null) {
        return
    }
    updateInspectorFromSelection()
}

