fun onModelFileSelected(path) {
    var kind = editor.addSceneAsset(path, 2, 0, 0)
    applyInitialPoseAfterLoad()
    updateScenePanel()
    activateArrangeMove()
    if (kind == 1) {
        var c = editor.getSceneCharacterCount() - 1
        if (c >= 0) {
            selectedSceneAssetIndex = c
            editor.selectSceneCharacter(c)
        }
    } else if (kind == 0) {
        var charCount = editor.getSceneCharacterCount()
        var p = editor.getScenePropCount() - 1
        if (p >= 0) {
            selectedSceneAssetIndex = charCount + p
            editor.selectSceneProp(p)
        }
    } else {
        selectFirstSceneAsset()
    }
    syncSceneToSource()
    statusLabel.text = "Loaded: " + path
}
