on btnPoseMode.clicked() {
    log.info("btnPoseMode.clicked (before) mode=" + currentMode + " pose=" + ui.getObject("btnPoseMode").buttonPressed + " arrange=" + ui.getObject("btnArrangeMode").buttonPressed)
    activatePoseMode()
    log.info("btnPoseMode.clicked (after) mode=" + currentMode + " pose=" + ui.getObject("btnPoseMode").buttonPressed + " arrange=" + ui.getObject("btnArrangeMode").buttonPressed)
    statusLabel.text = "Pose Mode"
}

on btnArrangeMode.clicked() {
    log.info("btnArrangeMode.clicked (before) mode=" + currentMode + " pose=" + ui.getObject("btnPoseMode").buttonPressed + " arrange=" + ui.getObject("btnArrangeMode").buttonPressed)
    activateArrangeMove()
    // Re-attach gizmo to already-selected scene asset (if any)
    var sel = selectedSceneAssetIndex
    if (sel >= 0) {
        var charCount = editor.getSceneCharacterCount()
        if (sel < charCount) {
            editor.selectSceneCharacter(sel)
        } else {
            var propIdx = sel - charCount
            if (propIdx >= 0) {
                editor.selectSceneProp(propIdx)
            }
        }
    }
    updateInspectorFromSelection()
    log.info("btnArrangeMode.clicked (after) mode=" + currentMode + " pose=" + ui.getObject("btnPoseMode").buttonPressed + " arrange=" + ui.getObject("btnArrangeMode").buttonPressed)
    statusLabel.text = "Arrange Mode"
}

on btnModeMove.clicked() {
    log.info("btnModeMove.clicked (before) edit=" + currentEditMode + " move=" + ui.getObject("btnModeMove").buttonPressed + " scale=" + ui.getObject("btnModeScale").buttonPressed + " rotate=" + ui.getObject("btnModeRotate").buttonPressed)
    currentEditMode = "move"
    ui.getObject("btnModeMove").buttonPressed = true
    ui.getObject("btnModeScale").buttonPressed = false
    ui.getObject("btnModeRotate").buttonPressed = false
    editor.setEditMode("move")
    log.info("btnModeMove.clicked (after) edit=" + currentEditMode + " move=" + ui.getObject("btnModeMove").buttonPressed + " scale=" + ui.getObject("btnModeScale").buttonPressed + " rotate=" + ui.getObject("btnModeRotate").buttonPressed)
}

on btnModeScale.clicked() {
    log.info("btnModeScale.clicked (before) edit=" + currentEditMode + " move=" + ui.getObject("btnModeMove").buttonPressed + " scale=" + ui.getObject("btnModeScale").buttonPressed + " rotate=" + ui.getObject("btnModeRotate").buttonPressed)
    currentEditMode = "scale"
    ui.getObject("btnModeMove").buttonPressed = false
    ui.getObject("btnModeScale").buttonPressed = true
    ui.getObject("btnModeRotate").buttonPressed = false
    editor.setEditMode("scale")
    log.info("btnModeScale.clicked (after) edit=" + currentEditMode + " move=" + ui.getObject("btnModeMove").buttonPressed + " scale=" + ui.getObject("btnModeScale").buttonPressed + " rotate=" + ui.getObject("btnModeRotate").buttonPressed)
}

on btnModeRotate.clicked() {
    log.info("btnModeRotate.clicked (before) edit=" + currentEditMode + " move=" + ui.getObject("btnModeMove").buttonPressed + " scale=" + ui.getObject("btnModeScale").buttonPressed + " rotate=" + ui.getObject("btnModeRotate").buttonPressed)
    currentEditMode = "rotate"
    ui.getObject("btnModeMove").buttonPressed = false
    ui.getObject("btnModeScale").buttonPressed = false
    ui.getObject("btnModeRotate").buttonPressed = true
    editor.setEditMode("rotate")
    log.info("btnModeRotate.clicked (after) edit=" + currentEditMode + " move=" + ui.getObject("btnModeMove").buttonPressed + " scale=" + ui.getObject("btnModeScale").buttonPressed + " rotate=" + ui.getObject("btnModeRotate").buttonPressed)
}

on btnPoseMode.toggled(value) {
    log.info("btnPoseMode.toggled value=" + value + " mode=" + currentMode)
}

on btnArrangeMode.toggled(value) {
    log.info("btnArrangeMode.toggled value=" + value + " mode=" + currentMode)
}

on btnModeMove.toggled(value) {
    log.info("btnModeMove.toggled value=" + value + " edit=" + currentEditMode)
}

on btnModeScale.toggled(value) {
    log.info("btnModeScale.toggled value=" + value + " edit=" + currentEditMode)
}

on btnModeRotate.toggled(value) {
    log.info("btnModeRotate.toggled value=" + value + " edit=" + currentEditMode)
}

on transformSpaceSelect.itemSelected(index) {
    applyTransformSpace(index)
    statusLabel.text = "Transform Space: " + currentTransformSpace
}

on transformSpaceSelect.clicked() {
    // OptionButton emits clicked in some runtime paths; keep handler to avoid warning spam.
}

// ── Viewport controls ─────────────────────────────────────────────────────────

on btnToggleJoints.clicked() {
    if (jointSpheresVisible) {
        jointSpheresVisible = false
        editor.setJointSpheresVisible(false)
        ui.getObject("btnToggleJoints").buttonPressed = false
        statusLabel.text = "Joints hidden."
    } else {
        jointSpheresVisible = true
        editor.setJointSpheresVisible(true)
        ui.getObject("btnToggleJoints").buttonPressed = true
        statusLabel.text = "Joints visible."
    }
}

// ── Project chooser ───────────────────────────────────────────────────────────

on btnChooserOpenLast.clicked() {
    var last = readLastProjectPath()
    if (last == "") {
        showProjectChooser("Last project not found. Choose Open or Create.")
        return
    }
    if (!openProjectPath(last)) {
        log.success("right before crash 5")
        showProjectChooser("Last project could not be opened.")
    }
}

on btnChooserOpen.clicked() {
    ui.openFileDialog("onProjectFileSelected", "*.scene")
}

on btnChooserCreate.clicked() {
    ui.openSaveFileDialog("onProjectCreatePathSelected", "*.scene")
}

on btnChooserThemePrev.clicked() {
    applyThemePreset(selectedThemeIndex - 1)
}

on btnChooserThemeNext.clicked() {
    applyThemePreset(selectedThemeIndex + 1)
}

on btnChooserCancel.clicked() {
    var win = ui.getObject("mainWindow")
    if (win != null) {
        var tree = win.getTree()
        if (tree != null) {
            tree.quit()
        } else {
            win.close()
        }
    }
}
